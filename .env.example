# Google Maps Platform (Geocoding + Static Maps + Solar API)
GOOGLE_MAPS_API_KEY=

# Anthropic (photo assessment via Claude vision)
ANTHROPIC_API_KEY=

# Cal.com (booking calendar)
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# Retell AI (voice agent)
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_AGENT_ID=

# Telnyx (SMS notifications to owner)
TELNYX_API_KEY=
TELNYX_FROM=+17162000707
OWNER_NOTIFY_PHONE=

# Resend (email notifications)
RESEND_API_KEY=
OWNER_NOTIFY_EMAIL=

# Airtable (lead storage)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Leads

# Google Business Profile (reviews — optional)
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=

# Cloudflare Turnstile (anti-spam)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Pricing (server-side only — never expose to client)
ROOF_PRICE_LOW_PER_SQFT=4.6
ROOF_PRICE_HIGH_PER_SQFT=7.2

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=

# App URL (for internal API calls from Retell webhook)
NEXTAUTH_URL=https://roofalo.com
